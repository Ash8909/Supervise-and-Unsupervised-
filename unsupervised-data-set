from sklearn.datasets import make_blobs
import matplotlib.pyplot as plt

# Generate an unsupervised dataset with 3 clusters
# X contains the features, y contains the cluster labels (which are typically unknown in unsupervised learning)
# We generate y for visualization/evaluation purposes in this example.
n_samples = 300
n_features = 2
n_clusters = 3

X, y = make_blobs(n_samples=n_samples, n_features=n_features, centers=n_clusters, random_state=42)

print(f"Shape of the dataset (X): {X.shape}")
print(f"Shape of the cluster labels (y): {y.shape}")

# Optional: Visualize the generated dataset
plt.figure(figsize=(8, 6))
plt.scatter(X[:, 0], X[:, 1], c=y, cmap='viridis', s=50, alpha=0.8)
plt.title('Generated Unsupervised Dataset (Blobs)')
plt.xlabel('Feature 1')
plt.ylabel('Feature 2')
plt.colorbar(label='Cluster Label')
plt.grid(True)
plt.show()

